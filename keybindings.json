[
    // begin: extension shortcuts
    // paste and align
    { "key": "ctrl+v",       "command": "pasteAndIndent.action",              "when": "editorTextFocus && !editorReadonly" },
    { "key": "ctrl+v",       "command": "editor.action.clipboardPasteAction", "when": "!editorTextFocus" },
    { "key": "ctrl+shift+v", "command": "editor.action.clipboardPasteAction", "when": "editorTextFocus && !editorReadonly" },
    // end: extension shortcuts

    // begin: /pc/ahk/keyboard.ahk > F13 & ...::tap_key()
    { "key": "f8",   "command": "-{editor.action.marker.nextInFiles", "when": "editorFocus" },
    // multicursor on word/match under cursor
    { "key": "f8 3", "command": "editor.action.addSelectionToPreviousFindMatch" },
    { "key": "f8 8", "command": "editor.action.addSelectionToNextFindMatch" },
    { "key": "ctrl+f8 ctrl+8", "command": "editor.action.selectHighlights" },
    // jump and peek source control (git) | hjkl alike
    { "key": "f8 y", "command": "editor.action.dirtydiff.previous", "when": "editorTextFocus && !textCompareEditorActive" },
    { "key": "f8 o", "command": "editor.action.dirtydiff.next",     "when": "editorTextFocus && !textCompareEditorActive" },
    // peek operations on dirty diff (peek widget)
        // @help because these donn't work I created an ahk @hack -> `/pc/ahk/file_pilot.ahk2`
        // { "key": "ctrl+g ctrl+r", "command": "git.revertChange"  }, // { "key": "ctrl+g ctrl+s", "command": "git.stageChange"   }, // { "key": "ctrl+g ctrl+b", "command": "diffEditor.revert" }, // 
        // { "key": "f8 p", "command": "ahk.hack.stage_change"  }, // { "key": "f8 [", "command": "ahk.hack.revert_change" }, // { "key": "capslock", "command": "ahk.hack.close_peek" },
    // diff editor
    { "key": "f8 p", "command": "workbench.action.compareEditor.focusOtherSide" },
    // jump to open source control (git) | hjkl alike
    { "key": "f8 u", "command": "workbench.action.editor.previousChange", "when": "textCompareEditorVisible || editorTextFocus && !textCompareEditorActive && quickDiffDecorationCount != '0'" },
    { "key": "f8 i", "command": "workbench.action.editor.nextChange",     "when": "textCompareEditorVisible || editorTextFocus && !textCompareEditorActive && quickDiffDecorationCount != '0'" },
        // split editor textCompareEditorVisible
        { "key": "f8 u",   "command": "workbench.action.compareEditor.previousChange", "when": "textCompareEditorVisible" },
        { "key": "f8 u",   "command": "workbench.action.editor.previousChange",        "when": "editorTextFocus && !textCompareEditorActive && quickDiffDecorationCount != '0'" },
        { "key": "f8 i",   "command": "workbench.action.compareEditor.nextChange",     "when": "textCompareEditorVisible" },
        { "key": "f8 i",   "command": "workbench.action.editor.nextChange",            "when": "editorTextFocus && !textCompareEditorActive && quickDiffDecorationCount != '0'" },
    // jump to errors | hjkl alike
    { "command": "runCommands", "key": "f8 ,", "when": "editorFocus", "args": { "commands": [
        "editor.action.marker.prev",
        // "vscode-neovim.escape",
    ]}},
    { "command": "runCommands", "key": "f8 m", "when": "editorFocus", "args": { "commands": [
        "editor.action.marker.next",
        // "vscode-neovim.escape",
    ]}},
    // { "key": "f8 m", "command": "editor.action.marker.next",  "when": "editorFocus" },
            { "key": "alt+f8",       "command": "-editor.action.marker.next", "when": "editorFocus" },
            { "key": "shift+alt+f8", "command": "-editor.action.marker.prev", "when": "editorFocus" },



    // focus toggle terminal
    { "key": "f8 ;", "command": "workbench.action.terminal.toggleTerminal", "when": "terminal.active" },
    // focus toggle debug console
    { "key": "f8 '", "command": "workbench.debug.action.toggleRepl", "when": "workbench.panel.repl.view.active" },
    { "key": "ctrl+shift+y", "command": "-workbench.debug.action.toggleRepl", "when": "workbench.panel.repl.view.active" },
    // end: /pc/ahk/keyboard.ahk > F13 & ...::tap_key()

    // begin: /pc/ahk/keyboard.ahk > d::key_modifier_r()
    // @note I forgot why I need to put the <F> remappings here and not in `vim.normalModeKeyBindingsNonRecursive`
    { "key": "f7 f", "command": "vim.remap", "when": "editorTextFocus && vim.mode != 'Insert'", "args": {
        "after": ["<space>", "<space>", "2", "s"]}},
    // clear vscode build in keys
    { "key": "f7", "command": "-editor.action.accessibleDiffViewer.next", "when": "isInDiffEditor" },
    { "key": "f7", "command": "-chatEditor.action.showAccessibleDiffView", "when": "accessibilityModeEnabled && chatEdits.hasEditorModifications && editorFocus && !chatEdits.isCurrentlyBeingModified" },
    { "key": "f7", "command": "-editor.action.wordHighlight.next", "when": "editorTextFocus && hasWordHighlights" },
    // end: /pc/ahk/keyboard.ahk > F13 & ...::tap_key_r()

    // begin: /pc/ahk/keyboard.ahk > d::key_modifier_r()
    // debugger customizations
    { "key": "f9",            "command": "-editor.debug.action.toggleBreakpoint",       "when": "debuggersAvailable && disassemblyViewFocus || debuggersAvailable && editorTextFocus" },
    { "key": "shift+f9",      "command": "-editor.debug.action.toggleInlineBreakpoint", "when": "editorTextFocus" },
    { "key": "shift+f9",      "command": "-settings.action.showContextMenu",            "when": "inSettingsEditor" },
    { "key": "ctrl+k ctrl+i", "command": "-editor.debug.action.showDebugHover",         "when": "editorTextFocus && inDebugMode" },
    // debug interaction tools
    { "key": "f9 c", "command": "editor.debug.action.selectionToRepl" },
    { "key": "f9 s", "command": "editor.debug.action.showDebugHover",         "when": "editorTextFocus && inDebugMode" },
    // watch-related
    { "key": "f9 w", "command": "editor.debug.action.selectionToWatch" },
    { "key": "f9 v", "command": "editor.debug.action.triggerByBreakpoint" },
    // edit
    { "key": "f9 e", "command": "editor.debug.action.editBreakpoint" },
    { "key": "f9 f", "command": "workbench.debug.viewlet.action.addFunctionBreakpointAction" },
    { "key": "f9 g", "command": "editor.debug.action.addLogPoint" },
    { "key": "f9 x", "command": "editor.debug.action.conditionalBreakpoint" },
    // go to
    { "key": "f9 r", "command": "workbench.debug.viewlet.action.reapplyBreakpointsAction" },
    { "key": "f9 t", "command": "editor.debug.action.stepIntoTargets" },
    { "key": "f9 ;", "command": "editor.debug.action.runToCursor" },
    // breakpoint manipulation
    { "key": "f9 h", "command": "editor.debug.action.toggleBreakpoint",       "when": "debuggersAvailable && disassemblyViewFocus || debuggersAvailable && editorTextFocus" },
    { "key": "f9 j", "command": "editor.debug.action.goToPreviousBreakpoint" },
    { "key": "f9 k", "command": "editor.debug.action.goToNextBreakpoint" },
    { "key": "f9 l", "command": "debug.enableOrDisableBreakpoint" },
    { "key": "f9 d", "command": "workbench.debug.viewlet.action.removeAllBreakpoints" },
    { "key": "f9 y", "command": "workbench.debug.viewlet.action.toggleBreakpointsActivatedAction" },
    { "key": "f9 u", "command": "editor.debug.action.toggleInlineBreakpoint", "when": "editorTextFocus" },
    { "key": "f9 i", "command": "editor.debug.action.toggleInlineBreakpoint", "when": "editorTextFocus" }, // @feedabck what to put here?
    { "key": "f9 o", "command": "workbench.debug.action.focusBreakpointsView" },
    // end: /pc/ahk/keyboard.ahk > d::d_key_modifier()

    // @hack vim extension gj gk
    // { "key": "down", "command": "vim.remap", "when": "editorTextFocus && vim.active && vim.mode != 'Insert'", "args": { "after": ["g", "j"] } },
    // { "key": "up", "command": "vim.remap", "when": "editorTextFocus && vim.active && vim.mode != 'Insert'", "args": { "after": ["g", "k"] } },

    // @hack to solve https://github.com/VSCodeVim/Vim/issues/1323
    // i like how multiple cursors behave, and the tradeoff is the vim stack history gets lost...
    { "key": "j", "command": "cursorMove", "args": { "to": "down", "by": "wrappedLine", "value": 1 }, "when": "editorTextFocus && vim.mode == 'Normal'" },
    { "key": "k", "command": "cursorMove", "args": { "to": "up", "by": "wrappedLine", "value": 1 }, "when": "editorTextFocus && vim.mode == 'Normal'" },


    // begin: vscode customizations
    // find search inside editor
    { "key": "alt+f",         "command": "actions.find", "when": "editorFocus || editorIsOpen" },
    { "key": "ctrl+g ctrl+a", "command": "git.stageAll" },
    // select all matches then to snake_case
    { "command": "runCommands", "key": "f8 9", "args": { "commands": [
        "editor.action.selectHighlights",
        "extension.changeCase.snake",
        // "extension.changeCase.pascal",
        // "workbench.action.toggleMultiCursorModifier",
        "vscode-neovim.escape",
        "vscode-neovim.escape",
        "vscode-neovim.escape",
        // "vscode-neovim.escape",
        "cancelSelection", 
        // "removeSecondaryCursors",
    ] } },

    // F4: or next search resulttto open in the last editor
    { "key": "f4",       "command": "-references-view.next",                    "when": "reference-list.hasResult && references-view.canNavigate"},
    { "key": "f4",       "command": "-search.action.focusNextSearchResult",     "when": "hasSearchResult || inSearchEditor"},
    { "key": "f4",       "command": "-goToNextReference",                       "when": "inReferenceSearchEditor || referenceSearchVisible"},
    { "key": "shift+f4", "command": "-search.action.focusPreviousSearchResult", "when": "inReferenceSearchEditor || referenceSearchVisible"},
    { "key": "F3",       "title": "my Go to Next Reference",                    "command": "runCommands", "args": { "commands": [ "workbench.action.focusSecondEditorGroup", "references-view.next" ]},                    "when": "reference-list.hasResult && references-view.canNavigate", }, 
    { "key": "F4",       "title": "my Search: Focus Next Search Result",        "command": "runCommands", "args": { "commands": [ "workbench.action.focusSecondEditorGroup", "search.action.focusNextSearchResult"  ]},    "when": "hasSearchResult || inSearchEditor", }, 
    { "key": "shift+F4", "title": "my Search: Focus Previous Search Result",    "command": "runCommands", "args": { "commands": [ "workbench.action.focusSecondEditorGroup", "search.action.focusPreviousSearchResult" ]}, "when": "hasSearchResult || inSearchEditor", }, 
    { "key": "F4", "title": "my goToNextReference", "command": "runCommands", "when": "inReferenceSearchEditor || referenceSearchVisible", "args": { "commands": [
        "workbench.action.focusSecondEditorGroup",
        "goToNextReference"
    ]}},
    { "key": "ctrl+g ctrl+s", "command": "git.unstageAll" },
    { "key": "shift+alt+l", "command": "workbench.action.focusNextGroup" },

    // to goto left and right editor groups

    { "key": "shift+alt+h", "command": "-references-view.showCallHierarchy", "when": "editorHasCallHierarchyProvider" },
    { "key": "shift+alt+h", "command": "-editor.showCallHierarchy", "when": "editorHasCallHierarchyProvider && editorTextFocus && !inReferenceSearchEditor" },
    // { "key": "shift+alt+h", "command": "workbench.action.focusPreviousGroup", "when": "!editorHasCallHierarchyProvider && !typeHierarchyVisible && !callHierarchyVisible" },

    { "key": "shift+alt+h", "command": "workbench.action.focusLeftGroup" },
    { "key": "ctrl+k ctrl+left", "command": "-workbench.action.focusLeftGroup" },

    { "key": "shift+alt+l", "command": "workbench.action.focusRightGroup" },
    { "key": "ctrl+k ctrl+right", "command": "-workbench.action.focusRightGroup" },

    { "key": "ctrl+shift+m", "command": "workbench.action.toggleMaximizeEditorGroup", "when": "editorPartMaximizedEditorGroup || editorPartMultipleEditorGroups" },
    { "key": "ctrl+k ctrl+m", "command": "-workbench.action.toggleMaximizeEditorGroup", "when": "editorPartMaximizedEditorGroup || editorPartMultipleEditorGroups" },

    { "key": "ctrl+shift+m", "command": "-workbench.actions.view.problems", "when": "workbench.panel.markers.view.active" },

    { "key": "ctrl+shift+m", "command": "workbench.action.toggleMaximizedPanel", "when": "panelFocus" },
    {
        "key": "ctrl+l",
        "command": "workbench.debug.panel.action.clearReplAction",
        "when": "panelFocus"
    },
    { "key": "f7", "command": "-editor.action.accessibleDiffViewer.next", "when": "isInDiffEditor" },
    { "key": "f7", "command": "-chatEditor.action.showAccessibleDiffView", "when": "accessibilityModeEnabled && chatEdits.hasEditorModifications && editorFocus && !chatEdits.isCurrentlyBeingModified" },
    { "key": "f7", "command": "-editor.action.wordHighlight.next", "when": "editorTextFocus && hasWordHighlights" },
    // end: vscode customizations
    

